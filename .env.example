MANOVARTA_ENV=dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-me
HF_TOKEN=
MANOVARTA_MODEL_PROVIDER=vertex
MANOVARTA_CHAT_PROVIDER=vertex
MANOVARTA_EXTRACTION_PROVIDER=vertex
MANOVARTA_SAFETY_PROVIDER=local
# Recommended split for the budget-safe final runtime:
# - live conversation + structured turn updates: Vertex Gemini
# - async clinical scoring worker: Aya checkpoint (base or your trained Aya path)
MANOVARTA_CHAT_MODEL=gemini-2.5-flash
MANOVARTA_EXTRACTION_MODEL=gemini-2.5-flash
MANOVARTA_VERTEX_PROJECT=
MANOVARTA_VERTEX_LOCATION=us-central1
MANOVARTA_LOCAL_LOAD_IN_4BIT=true
MANOVARTA_LOCAL_CHAT_ADAPTER=
MANOVARTA_LOCAL_EXTRACTION_ADAPTER=
MANOVARTA_LOCAL_SAFETY_ADAPTER=
# Aya worker overrides:
# MANOVARTA_EXTRACTION_PROVIDER=local
# MANOVARTA_EXTRACTION_MODEL=/models/aya-expanse-8b
# MANOVARTA_LOCAL_EXTRACTION_ADAPTER=/models/aya_bundle
MANOVARTA_HF_TIMEOUT=30
MANOVARTA_ASSISTANT_TEMPERATURE=0.2
MANOVARTA_ASSISTANT_MAX_TOKENS=180
MANOVARTA_SEMANTIC_SAFETY_MODEL=
MANOVARTA_SEMANTIC_REVIEW_THRESHOLD=0.64
MANOVARTA_SEMANTIC_URGENT_THRESHOLD=0.72
MANOVARTA_ENABLE_CLOUD_VOICE=
# Optional override. If unset, runtime auto-discovers
# outputs/local_safety_boost/safety-indicbert-best-infer-fp16
# or outputs/local_safety_boost/safety-indicbert-best when present.
MANOVARTA_LOCAL_SAFETY_CHECKPOINT=
MANOVARTA_LOCAL_SAFETY_CHECKPOINT_GCS_URI=
MANOVARTA_ASYNC_SCORING_ENABLED=true
MANOVARTA_ASYNC_SCORING_DIR=artifacts/async_scoring
MANOVARTA_PUBLIC_BASE_URL=
